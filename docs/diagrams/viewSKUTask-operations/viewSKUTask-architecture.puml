@startuml
!include ../style.puml
skinparam arrowThickness 1.1
skinparam classAttributeIconSize 0
hide circle

class ItemTasker UI_COLOR_T1 {
  + main(args: String[])
}

class CommandRunner LOGIC_COLOR {
  - skuList: SKUList
  - viewHandler: ViewCommandHandler
  + run(cmd: ParsedCommand): void
}

class ViewCommandHandler LOGIC_COLOR_T2 {
  - skuList: SKUList
  + handleListTasks(cmd: ParsedCommand): void
  - listTasksByDistance(loc: String): void
  - formatDistanceEntries(tasks: List, loc: String): List<String>
}

class ViewSKUTask LOGIC_COLOR_T3 {
  - skuFilter: String
  - priorityFilter: String
  - locationFilter: String
  + listTasks(fullList: SKUList): List<SKUTask>
  + calculateDistance(task: SKUTask, pos: String, list: SKUList): int
}

class SKUList MODEL_COLOR {
  + getSKUList(): List<SKU>
  + findByID(id: String): SKU
}

class SKU MODEL_COLOR_T1 {
  - skuID: String
  - skuLocation: Location
  + getSKUTaskList(): SKUTaskList
}

class SKUTaskList MODEL_COLOR_T2 {
  + getSKUTaskList(): List<SKUTask>
}

class SKUTask MODEL_COLOR_T3 {
  - skuTaskID: String
  - priority: Priority
  + getSKUTaskID(): String
}

ItemTasker ..> CommandRunner : invokes >
CommandRunner *-down-> "1" ViewCommandHandler : dispatches to >
ViewCommandHandler .down.> ViewSKUTask : creates >

ViewCommandHandler -right-> "1" SKUList
ViewSKUTask .right.> SKUList : queries for locations >

SKUList *-down-> "*" SKU
SKU *-down-> "1" SKUTaskList
SKUTaskList *-down-> "*" SKUTask

@enduml