@startuml
!include ../style.puml
skinparam arrowThickness 1.1
skinparam classAttributeIconSize 0
hide circle

class TaskCommandHandler LOGIC_COLOR {
  + handleMarkTask(cmd: ParsedCommand): void
  + handleUnmarkTask(cmd: ParsedCommand): void
}

class CommandHelper LOGIC_COLOR {
  + {static} findSkuOrError(skuList: SKUList, skuId: String): SKU
  + {static} parseIndex(indexStr: String): int
}

class SKUList MODEL_COLOR {
}

class SKU MODEL_COLOR_T1 {
  - skuID: String
  - skuLocation: Location
}

class SKUTaskList MODEL_COLOR_T2 {
  + markTask(index: int): void
  + unmarkTask(index: int): void
  + getSize(): int
  + getSKUTaskList(): ArrayList<SKUTask>
}

class SKUTask MODEL_COLOR_T3 {
  - skuTaskID: String
  - priority: Priority
  - dueDate: String
  - isDone: boolean
  - taskDescription: String
  + mark(): void
  + unmark(): void
  + isDone(): boolean
}

TaskCommandHandler -down-> "1" SKUList : skuList
TaskCommandHandler ..> CommandHelper : uses
SKUList -down-> "*" SKU : skuList
SKU -down-> "1" SKUTaskList : skuTaskList
SKUTaskList -down-> "*" SKUTask : skuTaskList
@enduml