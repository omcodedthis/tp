@startuml
!include ../style.puml

Participant ":CommandRunner" as runner LOGIC_COLOR
Participant ":ViewCommandHandler" as handler LOGIC_COLOR_T2
Participant ":ParsedCommand" as cmd LOGIC_COLOR_T1
Participant ":CommandHelper" as helper LOGIC_COLOR_T1
Participant ":SKUList" as skuList MODEL_COLOR
Participant ":Ui" as ui UI_COLOR

== handleFind - validation ==

runner -> handler ++ : handleFind(cmd)

handler -> cmd ++ : getArg()
note right : called 3 times - getArg("n"), getArg("t"), getArg("i")\nn/SKU filter, t/description filter, i/index filter - all optional
return skuFilter, descFilter, indexStr

handler -> ui : printSearchHeader()

handler -> handler ++ : validateFindArgs(skuFilter, descFilter, indexStr)

opt skuFilter == null and descFilter == null and indexStr == null
    note right : throws MissingArgumentException
end

opt skuFilter != null
    handler -> skuList ++ : findByID(skuFilter)
    return sku / null

    opt sku == null
        note right : throws SKUNotFoundException
    end
end

return

opt indexStr != null
    handler -> helper ++ : parseIndex(indexStr)
    return taskIndex
end

== handleFind - search ==

handler -> handler ++ : searchTasks(skuFilter, descFilter, taskIndex)

loop for each SKU in skuList.getSKUList()
    opt skuFilter != null and sku.getSKUID() does not match
        note right : skip this SKU
    end

    handler -> handler ++ : searchTasksInSku(sku, descFilter, taskIndex, hasSkuFilter, results)

    alt taskIndex > 0
        handler -> handler ++ : searchByIndex(sku, tasks, descFilter, taskIndex, hasSkuFilter, results)

        alt taskIndex > tasks.size()
            alt hasSkuFilter == true
                note right : throws InvalidIndexException
            else
                note right : skip silently
            end
        else
            note over handler : task = tasks.get(taskIndex - 1)

            handler -> helper ++ : matchesDescription(task, descFilter)
            return matches

            opt matches
                handler -> handler ++ : formatSearchResult(skuId, taskIndex, task)
                return formatted entry
            end
        end

        return

    else taskIndex <= 0
        handler -> handler ++ : searchAllTasks(sku, tasks, descFilter, results)

        loop for each task in tasks
            handler -> helper ++ : matchesDescription(task, descFilter)
            return matches

            opt matches
                handler -> handler ++ : formatSearchResult(skuId, i+1, task)
                return formatted entry
            end
        end

        return
    end

    return
end

return results

handler -> ui : printSearchFooter(results)

return
@enduml
