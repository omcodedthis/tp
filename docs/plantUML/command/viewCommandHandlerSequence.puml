@startuml
!include ../style.puml

Participant ":CommandRunner" as runner LOGIC_COLOR
Participant ":ViewCommandHandler" as handler LOGIC_COLOR_T2
Participant ":ParsedCommand" as cmd LOGIC_COLOR_T1
Participant ":CommandHelper" as helper LOGIC_COLOR_T1
Participant ":ViewSKUTask" as viewer LOGIC_COLOR_T1
Participant ":SKUList" as skuList MODEL_COLOR
Participant ":SKUTask" as task MODEL_COLOR_T2
Participant ":Ui" as ui UI_COLOR

== handleListTasks ==

runner -> handler ++ : handleListTasks(cmd)

handler -> cmd ++ : getArg("n"), getArg("p"), getArg("l")
return skuFilter, priorityFilter, locationFilter

alt skuFilter != null
    handler -> skuList ++ : findByID(skuFilter)
    return targetSku

    alt targetSku == null or task list empty
        handler -> ui : printInfo("No tasks found for SKU: ...")
    else
        handler -> viewer ++ : setSkuFilter(skuFilter)
        return

        handler -> viewer ++ : listTasks(skuList)
        return results

        handler -> ui : printTasksForSku(skuFilter, results)
    end

else priorityFilter != null
    handler -> helper ++ : parsePriority(priorityFilter)
    return priority / null

    alt priority == null
        note right : returns early
    else
        handler -> viewer ++ : setPriorityFilter(priorityFilter)
        return

        handler -> viewer ++ : listTasks(skuList)
        return results

        handler -> ui : printTasksByPriority(priorityFilter, results)
    end

else locationFilter != null
    handler -> helper ++ : parseLocation(locationFilter)
    return location / null

    alt location == null
        note right : returns early
    else
        handler -> viewer ++ : setLocationFilter(locationFilter)
        return

        handler -> viewer ++ : listTasks(skuList)
        return results

        handler -> handler ++ : formatDistanceEntries(results, locationFilter)

        loop for each task in results
            handler -> skuList ++ : findByID(task.getSKUTaskID())
            return skuObj

            alt skuObj == null
                note right : skip
            else
                handler -> viewer ++ : calculateDistance(task, locationFilter, skuList)
                return dist
            end
        end

        return formattedEntries

        handler -> ui : printTasksByDistance(from, formattedEntries)
    end

else no filter provided
    handler -> ui : printAllTasks(skuList)
end

return

== handleFind — validation ==

runner -> handler ++ : handleFind(cmd)

handler -> cmd ++ : getArg("n"), getArg("t"), getArg("i")
return skuFilter, descFilter, indexStr

handler -> handler ++ : validateFindArgs(skuFilter, descFilter, indexStr)

alt all three filters null
    handler -> runner : throw MissingArgumentException
end

alt skuFilter != null
    handler -> skuList ++ : findByID(skuFilter)
    return sku / null

    alt sku == null
        handler -> runner : throw SKUNotFoundException
    end
end

return

alt indexStr != null
    handler -> helper ++ : parseIndex(indexStr)
    return taskIndex / -1

    alt taskIndex == -1
        note right : returns early
    end
end

handler -> ui : printSearchHeader()

== handleFind — search ==

handler -> handler ++ : searchTasks(skuFilter, descFilter, taskIndex)

loop for each SKU in skuList.getSKUList()
    alt skuFilter != null and sku.getSKUID() does not match
        note right : skip this SKU
    end

    handler -> handler ++ : searchTasksInSku(sku, descFilter, taskIndex, hasSkuFilter, results)

    alt taskIndex > 0
        handler -> handler ++ : searchByIndex(sku, tasks, descFilter, taskIndex, hasSkuFilter, results)

        alt taskIndex > tasks.size()
            alt hasSkuFilter == true
                handler -> runner : throw InvalidIndexException
            else
                note right : skip silently
            end
        else
            handler -> task ++ : (tasks.get(taskIndex - 1))
            return task

            handler -> helper ++ : matchesDescription(task, descFilter)
            return boolean

            alt matches
                handler -> handler ++ : formatSearchResult(skuId, taskIndex, task)
                return formatted entry
            end
        end

        return
    else taskIndex <= 0
        handler -> handler ++ : searchAllTasks(sku, tasks, descFilter, results)

        loop for each task in tasks
            handler -> helper ++ : matchesDescription(task, descFilter)
            return boolean

            alt matches
                handler -> handler ++ : formatSearchResult(skuId, i+1, task)
                return formatted entry
            end
        end

        return
    end

    return
end

return results

handler -> ui : printSearchFooter(results)

return
@enduml
