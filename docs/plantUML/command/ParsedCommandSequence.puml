@startuml
!include ../style.puml

Actor User as user USER_COLOR
Participant ":Ui" as ui UI_COLOR
Participant ":Parser" as parser LOGIC_COLOR_T1
Participant ":ParsedCommand" as cmd MODEL_COLOR
Participant ":CommandRunner" as runner LOGIC_COLOR

user -> ui ++ : "addsku n/P-A l/A1"
ui -> parser ++ : parse(input)

parser -> parser ++ : split input → commandWord, argsString
return

parser -> parser ++ : parseFlags(argsString)
return Map<String, String>

parser -> cmd ** : new ParsedCommand("addsku", args)
return cmd : ParsedCommand

ui -> runner ++ : run(cmd)

runner -> cmd ++ : getCommandWord()
return "addsku"

runner -> cmd ++ : getArg("n")
return "P-A"

runner -> cmd ++ : getArg("l")
return "A1"

runner -> cmd ++ : hasArg("p")
return false

return
return

@enduml