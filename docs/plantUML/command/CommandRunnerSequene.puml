@startuml
!include ../style.puml

Actor User as user USER_COLOR
Participant ":Ui" as ui UI_COLOR
Participant ":Parser" as parser LOGIC_COLOR_T1
Participant ":CommandRunner" as runner LOGIC_COLOR
Participant ":SKUList" as skuList MODEL_COLOR
Participant ":SKU" as sku MODEL_COLOR_T1
Participant ":SKUTaskList" as taskList MODEL_COLOR_T2

user -> ui ++ : "addskutask n/P-A d/2025-12-31 p/HIGH t/restock"
ui -> parser ++ : parse(...)
return cmd : ParsedCommand

ui -> runner ++ : run(cmd)
runner -> runner ++ : handleAddSkuTask(cmd)

runner -> runner ++ : findSku("P-A")
runner -> skuList ++ : getSKUList()
return List<SKU>
return targetSku : SKU

alt targetSku == null
    runner -> ui : printError("SKU not found")
else targetSku found
    runner -> sku ++ : getSKUTaskList()
    return taskList : SKUTaskList

    runner -> taskList ++ : addSKUTask("P-A", HIGH, "2025-12-31", "restock")
    return

    runner -> taskList ++ : getSize()
    return newIndex

    runner -> ui : printSuccess("Added task #newIndex ...")
end

return
return
return

@enduml