@startuml
!include ../style.puml

Participant ":ItemTasker" as app LOGIC_COLOR
Participant ":Parser" as parser LOGIC_COLOR_T1
Participant ":ParsedCommand" as cmd LOGIC_COLOR_T1

== parse ==

app -> parser ++ : parse(input)

note right : assert input != null

parser -> parser : trimmed = input.trim()

alt trimmed.isEmpty()
    parser -> cmd ++ : new ParsedCommand("", new HashMap<>())
    return
    return empty ParsedCommand
end

parser -> parser : parts = trimmed.split("\\s+", 2)
parser -> parser : commandWord = parts[0].toLowerCase()

alt parts.length > 1
    parser -> parser ++ : parseFlags(parts[1].trim())
    return args map
else no flags present
    parser -> parser : args = new HashMap<>()
end

parser -> cmd ++ : new ParsedCommand(commandWord, args)
return

return ParsedCommand

== parseFlags ==

app -> parser ++ : parseFlags(argsString)

parser -> parser : tokens = argsString.split("(?<=\\S)\\s+(?=[a-zA-Z]/)")

loop for each token in tokens
    parser -> parser : slashIdx = token.indexOf('/')

    alt slashIdx > 0
        parser -> parser : key = token.substring(0, slashIdx).trim().toLowerCase()
        parser -> parser : value = token.substring(slashIdx + 1).trim()
        parser -> parser : args.put(key, value)
    else no slash found
        note right : token ignored (no valid flag)
    end
end

return args map
@enduml
