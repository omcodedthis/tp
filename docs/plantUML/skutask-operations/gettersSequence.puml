@startuml
!include ../style.puml

Actor User as user USER_COLOR
Participant ":Ui" as ui UI_COLOR
Participant ":Parser" as parser LOGIC_COLOR_T1
Participant ":CommandRunner" as runner LOGIC_COLOR
Participant ":SKUList" as skuList MODEL_COLOR
Participant ":SKU" as sku MODEL_COLOR_T1
Participant ":SKUTaskList" as taskList MODEL_COLOR_T2
Participant ":SKUTask" as task MODEL_COLOR_T3

user -> ui ++ : "listtasks n/P-A"
ui -> parser ++ : parse(...)
return cmd : ParsedCommand

ui -> runner ++ : run(cmd)
runner -> runner ++ : handleListTasks(cmd)

runner -> runner ++ : findSku("P-A")
runner -> skuList ++ : getSKUList()
return List<SKU>
return targetSku

runner -> sku ++ : getSKUTaskList()
return taskList

runner -> taskList ++ : getSKUTaskList()
return ArrayList<SKUTask>

loop for each printed task
    runner -> task ++ : toString()
    task -> task ++ : isDone()
    return isDone
    task -> task ++ : getSKUTaskID()
    return id
    task -> task ++ : getSKUTaskPriority()
    return priority
    task -> task ++ : getSKUTaskDueDate()
    return dueDate
    return formattedString
end

return
return
return display tasks
@enduml
