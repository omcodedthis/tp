return cmd : ParsedCommand

ui -> runner ++ : run(cmd)
runner -> handler ++ : handleEditSku(cmd)

handler -> helper ++ : findSkuOrError(skuList, "PALLET-A")
helper -> skuList ++ : findByID("PALLET-A")
return sku
return sku

handler -> helper ++ : parseLocation("C3")
return C3

handler -> sku ++ : setLocation(C3)
return

return
return
return display success message
