@startuml
!include ../style.puml

Participant ":CommandRunner" as runner LOGIC_COLOR
Participant ":storageSystem" as storage LOGIC_COLOR_T1
Participant ":SKUList" as skuList MODEL_COLOR
Participant ":SKUTaskList" as taskList MODEL_COLOR_T2
Participant "storage.json" as file UI_COLOR

== saveState ==

runner -> storage ++ : saveState(skuList, taskMap)

storage -> storage ++ : create Data/ dir if not exists
return

storage -> skuList ++ : getSKUList()
return List<SKU>

storage -> taskList ++ : (serialize via Gson)
return JsonElement

storage -> file ++ : write root JsonObject to storage.json
return

return

== loadState ==

runner -> storage ++ : loadState(skuList, taskMap)

storage -> file ++ : check file exists
return exists / not exists

alt file exists
    storage -> file ++ : read storage.json
    return JsonObject

    storage -> storage ++ : fromJson → loadedSkus : SKUList
    return loadedSkus

    storage -> storage ++ : fromJson → loadedMap : HashMap
    return loadedMap

    storage -> skuList ++ : getSKUList().addAll(loadedSkus)
    return

    storage -> taskList ++ : taskMap.putAll(loadedMap)
    return
else file not found
    storage -> runner : return (no-op)
end

return
@enduml